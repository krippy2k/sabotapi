# Node.js Development Environment
PORT=5500
NODE_ENV=development

# Database Configuration
# For local development, embedded-postgres is used by default
# For production deployment, you need a standalone PostgreSQL database
DATABASE_URL={{DATABASE_URL}}

# Node postgres-js pool size (ignored for Neon serverless). Default 10.
DB_POOL_MAX=10

# Firebase Configuration (JWKS approach)
FIREBASE_PROJECT_ID={{FIREBASE_PROJECT_ID}}

# Firebase Auth emulator (set automatically by pnpm run dev when using local auth)
# USE_FIREBASE_EMULATOR=true

# Allow anonymous Firebase users on the server (must match VITE_ALLOW_ANONYMOUS_USERS in ui/.env.local)
# ALLOW_ANONYMOUS_USERS=true

# Cloudflare Configuration
WORKER_NAME={{WORKER_NAME}}
